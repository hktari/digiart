{
  "name": "art-subscription-platform",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter mvp dev",
    "dev:worker": "pnpm --filter pdf-worker dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "prepare": "husky",
    "pod:list-offerings": "pnpm --filter mvp pod:list-offerings",
    "pod:sync-countries": "pnpm --filter mvp pod:sync-countries"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
