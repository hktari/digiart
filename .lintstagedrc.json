{
  "*.{json,yaml,yml,md}": [],
  "apps/mvp/prisma/schema.prisma": "cd apps/mvp && dotenv -- prisma validate",
  "apps/mvp/prisma/migrations/**/*.sql": "node scripts/validate-migrations.js",
  "apps/mvp/**/*.{ts,tsx,js,jsx}": "pnpm --filter mvp lint:format",
  "apps/pdf-worker/**/*.{ts,tsx,js,jsx}": "pnpm --filter pdf-worker lint:format"
}
