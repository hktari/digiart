# Integration Test Environment Variables
#
# Copy this file to .env.test and fill in your values.
# WARNING: These tests will write to the database!
# Use a dedicated Neon test branch, NOT production.

# =============================================================================
# DATABASE (Required)
# =============================================================================
# Neon test branch URL
# Create a test branch: https://neon.tech/docs/introduction/branches
DATABASE_URL="postgresql://user:password@host.neon.tech/test-db?sslmode=require"

# =============================================================================
# REDIS (Required for BullMQ tests)
# =============================================================================
# Local Redis (default)
REDIS_URL="redis://localhost:6379"

# Or use Docker:
# docker run -d -p 6379:6379 --name test-redis redis:7-alpine

# =============================================================================
# STORAGE (Mocked for tests)
# =============================================================================
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/tmp/test-uploads
AWS_S3_BUCKET=test-bucket
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# =============================================================================
# AUTH (Required for API tests)
# =============================================================================
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET="your-test-auth-secret-min-32-chars-long"

# Auth bypass for tests (non-production only)
# When set, auth() returns this user without email verification
# Create a test user first via test:seed or manually
AUTH_BYPASS_TEST_USER_ID="test-user-id-from-database"

# =============================================================================
# OPTIONAL: Email (mocked in tests)
# =============================================================================
AUTH_RESEND_KEY=test-resend-key
EMAIL_FROM="test@example.com"
