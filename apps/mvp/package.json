{
  "name": "mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3003",
    "build": "next build",
    "start": "next start",
    "format": "biome format --write",
    "lint:format": "biome check --write --unsafe --no-errors-on-unmatched",
    "db:generate": "dotenv -- prisma generate",
    "db:migrate": "dotenv -- prisma migrate dev",
    "db:push": "dotenv -- prisma db push",
    "db:studio": "dotenv -- prisma studio",
    "typecheck": "tsc --noEmit",
    "dev:seed": "dotenv -- tsx scripts/reset-test-db.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:server": "node scripts/dev-with-test-env.js",
    "test:e2e": "dotenv -f .env.test -- playwright test --reporter 'list'",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test --config playwright.smoke.config.ts",
    "test:integration": "dotenv -e .env.test -- vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "dotenv -e .env.test -- vitest --config vitest.config.integration.ts",
    "db:seed:production": "dotenv -- tsx scripts/seed-production.ts",
    "db:seed:production:railway": "tsx scripts/seed-production.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "test:peecho": "dotenv -e .env.test -- tsx scripts/test-peecho-integration.ts",
    "test:coverage": "vitest run --coverage",
    "test:backend": "vitest run lib/__tests__ app/api/__tests__",
    "pod:sync-countries": "dotenv -- tsx scripts/sync-peecho-countries.ts",
    "pod:list-offerings": "dotenv -- tsx scripts/list-peecho-offerings.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@sentry/nextjs": "^10.51.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "bullmq": "^5.76.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.477.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "posthog-js": "^1.372.9",
    "posthog-node": "^4.0.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "resend": "^4.8.0",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^29.1.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
