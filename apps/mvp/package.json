{
  "name": "mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check --write --unsafe",
    "format": "biome check --write --unsafe",
    "db:generate": "dotenv -- prisma generate",
    "db:migrate": "dotenv -- prisma migrate dev",
    "db:push": "dotenv -- prisma db push",
    "db:studio": "dotenv -- prisma studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test --config playwright.smoke.config.ts",
    "test:integration": "dotenv -e .env.test -- vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "dotenv -e .env.test -- vitest --config vitest.config.integration.ts",
    "test:seed": "dotenv -- tsx scripts/seed-test-user.ts",
    "db:seed": "dotenv -- tsx scripts/seed-test-user.ts",
    "db:seed:production": "dotenv -- tsx scripts/seed-production.ts",
    "test:peecho": "dotenv -e .env.test -- tsx scripts/test-peecho-integration.ts",
    "test:coverage": "vitest run --coverage",
    "test:backend": "vitest run lib/__tests__ app/api/__tests__"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-avatar": "^1.1.7",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "bullmq": "^5.75.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.477.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.16.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "resend": "^4.5.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.2.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@faker-js/faker": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@types/supertest": "^6.0.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "supertest": "^7.0.0",
    "jsdom": "^29.0.2",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
