

# Neon test branch database URL
DATABASE_URL_TEST="postgresql://user:password@host/database?sslmode=require"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mvp_db"

# NextAuth
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# Email (Resend)
AUTH_RESEND_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# Peecho (API v3)
PEECHO_MERCHANT_API_KEY=""
PEECHO_ENV="sandbox"
PEECHO_OFFERING_IDS="7011271"

# Platform markup (fixed amount added to quotes for UX transparency)
PLATFORM_MARKUP_EUR="5.00"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# PayPal Payouts
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_ENVIRONMENT="sandbox"

# AWS S3 (artwork storage + generated PDF storage)
# For MinIO local dev: AWS_ENDPOINT_URL=http://localhost:9000
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_ENDPOINT_URL=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev / E2E auth bypass (non-production only)
# Set AUTH_BYPASS_TEST_USER_ID to skip magic link in local dev / E2E tests.
# Run `pnpm test:reset` to reset+seed test/dev data and write session tokens to .env.test.local.
# AUTH_BYPASS_TEST_USER_ID="uuid-of-seeded-test-user"
# AUTH_BYPASS_ROLES="CREATOR,COLLECTOR,ADMIN"  # optional: override roles without DB changes
ADMIN_EMAIL="admin@example.com"
