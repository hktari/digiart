generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth and identity (NextAuth v5 / Auth.js)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  roles    UserRole[]

  creatorProfile   CreatorProfile?
  collectorProfile CollectorProfile?

  notificationPreference NotificationPreference?
  emailNotificationLogs  EmailNotificationLog[]
  lead                   Lead?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  CREATOR
  COLLECTOR
  ADMIN
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

// ---------------------------------------------------------------------------
// Creator data
// ---------------------------------------------------------------------------

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model CreatorProfile {
  id             String        @id @default(cuid())
  userId         String        @unique
  slug           String        @unique
  displayName    String
  avatar         String?
  bio            String?       @db.Text
  sourcePlatform String? // Where creator is coming from (ArtStation, DeviantArt, Instagram, etc.)
  referralCode   String?       @unique // short code for tracking follower signups (e.g. "artbykarim")
  status              PublishStatus @default(DRAFT)
  onboardingComplete  Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user          User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutProfile CreatorPayoutProfile?
  socialLinks   CreatorSocialLink[]
  artworks      Artwork[]
  releases      Release[]
  subscriptions CollectorCreatorSubscription[]
  payouts       CreatorPayout[]
  profileViews  CreatorProfileView[]
  leads         Lead[]
}

model CreatorPayoutProfile {
  id               String    @id @default(cuid())
  creatorProfileId String    @unique
  taxId            String?
  bankAccountInfo  String?   @db.Text
  paypalEmail      String?
  paypalAccountId  String? // PayPal payer_id from OAuth verification
  isPayPalVerified Boolean   @default(false)
  payPalVerifiedAt DateTime?
  isReady          Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
}

model CreatorSocialLink {
  id               String @id @default(cuid())
  creatorProfileId String
  label            String
  url              String
  sortOrder        Int    @default(0)

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, label])
}

// ---------------------------------------------------------------------------
// Collector data
// ---------------------------------------------------------------------------

enum OnboardingState {
  PENDING
  SHIPPING_SET
  COMPLETE
}

model CollectorProfile {
  id                   String          @id @default(cuid())
  userId               String          @unique
  displayName          String?
  shippingCountry      String?
  shippingStateCode    String?
  shippingName         String?
  shippingAddressLine1 String?
  shippingAddressLine2 String?
  shippingCity         String?
  shippingZip          String?
  stripeCustomerId     String?
  onboardingState      OnboardingState @default(PENDING)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  user                User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions       CollectorCreatorSubscription[]
  selections          CollectorReleaseSelection[]
  priceQuotes         PricingQuoteSnapshot[]
  generatedPrintFiles GeneratedPrintFile[]
  checkoutIntents     CheckoutIntent[]
  billingRecords      BillingRecord[]
  fulfillmentOrders   FulfillmentOrder[]
}

// ---------------------------------------------------------------------------
// Content and release data
// ---------------------------------------------------------------------------

enum ArtworkStatus {
  ACTIVE
  ARCHIVED
}

enum Orientation {
  PORTRAIT
  LANDSCAPE
  SQUARE
  UNKNOWN
}

model Artwork {
  id               String        @id @default(cuid())
  creatorProfileId String
  title            String
  storageKey       String
  mimeType         String?
  fileSize         Int?
  width            Int?
  height           Int?
  orientation      Orientation   @default(UNKNOWN)
  status           ArtworkStatus @default(ACTIVE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  creatorProfile  CreatorProfile   @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  releaseArtworks ReleaseArtwork[]
}

model Release {
  id               String        @id @default(cuid())
  creatorProfileId String
  cycleId          String?
  title            String
  description      String?       @db.Text
  artworkLimit     Int           @default(10)
  status           PublishStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  publishedAt      DateTime?     // Set when release is first published (immutable after publish)

  creatorProfile CreatorProfile              @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  cycle          SubscriptionCycle?          @relation(fields: [cycleId], references: [id])
  artworks       ReleaseArtwork[]
  tags           ReleaseTag[]
  selections     CollectorReleaseSelection[]
}

model ReleaseArtwork {
  id        String @id @default(cuid())
  releaseId String
  artworkId String
  sortOrder Int    @default(0)

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([releaseId, artworkId])
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  releaseTags ReleaseTag[]
}

model ReleaseTag {
  releaseId String
  tagId     String

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([releaseId, tagId])
}

// ---------------------------------------------------------------------------
// Collector selection data
// ---------------------------------------------------------------------------

model CollectorCreatorSubscription {
  id                 String   @id @default(cuid())
  collectorProfileId String
  creatorProfileId   String
  isActive           Boolean  @default(true)
  entryCreatorId     String?
  referralCode       String?  // referral code present when the subscription was created
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  collectorProfile CollectorProfile @relation(fields: [collectorProfileId], references: [id], onDelete: Cascade)
  creatorProfile   CreatorProfile   @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([collectorProfileId, creatorProfileId])
}

model CollectorReleaseSelection {
  id                 String   @id @default(cuid())
  collectorProfileId String
  releaseId          String
  cycleId            String
  createdAt          DateTime @default(now())

  collectorProfile CollectorProfile  @relation(fields: [collectorProfileId], references: [id], onDelete: Cascade)
  release          Release           @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  cycle            SubscriptionCycle @relation(fields: [cycleId], references: [id])

  @@unique([collectorProfileId, releaseId, cycleId])
}

// ---------------------------------------------------------------------------
// Cycle and constraints
// ---------------------------------------------------------------------------

enum CycleStatus {
  OPEN
  LOCKED
  PROCESSING
  COMPLETE
}

model SubscriptionCycle {
  id                String      @id @default(cuid())
  label             String
  month             Int
  year              Int
  selectionOpenDate DateTime
  lockDate          DateTime
  fulfillmentDate   DateTime
  status            CycleStatus @default(OPEN)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  releases            Release[]
  selections          CollectorReleaseSelection[]
  quotes              PricingQuoteSnapshot[]
  emailLogs           EmailNotificationLog[]
  generatedPrintFiles GeneratedPrintFile[]
  checkoutIntents     CheckoutIntent[]
  billingRecords      BillingRecord[]
  fulfillmentOrders   FulfillmentOrder[]
  payoutCalculations  PayoutCalculation[]
  creatorPayouts      CreatorPayout[]
  profileViews        CreatorProfileView[]

  @@unique([month, year])
}

model BookletConstraint {
  id          String   @id @default(cuid())
  minPages    Int
  maxPages    Int
  maxCreators Int?
  maxReleases Int?
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// POD pricing and product config
// ---------------------------------------------------------------------------

enum PodEnvironment {
  SANDBOX
  PRODUCTION
}

model PodProviderConfig {
  id          String         @id @default(cuid())
  provider    String
  environment PodEnvironment @default(SANDBOX)
  isActive    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  offerings PodOffering[]
}

model PodOffering {
  id          String    @id @default(cuid())
  providerId  String
  externalId  String
  name        String
  minPages    Int
  maxPages    Int
  widthMm     Float?
  heightMm    Float?
  pricingMeta Json?
  isActive    Boolean   @default(true)
  syncedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  provider PodProviderConfig      @relation(fields: [providerId], references: [id])
  quotes   PricingQuoteSnapshot[]

  @@unique([providerId, externalId])
}

enum FulfillmentRegion {
  EU
  US
  OTHER
}

model FulfillmentCountry {
  code      String            @id
  name      String
  region    FulfillmentRegion  @default(OTHER)
  isActive  Boolean           @default(true)
  source    String            @default("peecho")
  syncedAt  DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([region, isActive])
}

model FulfillmentState {
  countryCode String
  stateCode   String
  name        String
  isActive    Boolean  @default(true)
  source      String   @default("peecho")
  syncedAt    DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@id([countryCode, stateCode])
  @@index([countryCode, isActive])
}

model PricingQuoteSnapshot {
  id                 String    @id @default(cuid())
  collectorProfileId String
  cycleId            String
  offeringId         String
  country            String
  requestedPageCount Int
  shippingAmount     Decimal   @db.Decimal(10, 2)
  productAmount      Decimal   @db.Decimal(10, 2)
  taxAmount          Decimal   @db.Decimal(10, 2)
  markupAmount       Decimal?  @db.Decimal(10, 2)
  totalEstimate      Decimal   @db.Decimal(10, 2)
  currency           String    @default("EUR")
  isFrozen           Boolean   @default(false)
  frozenAt           DateTime?
  quoteMetadataHash  String?
  quotedAt           DateTime  @default(now())

  collectorProfile  CollectorProfile   @relation(fields: [collectorProfileId], references: [id], onDelete: Cascade)
  cycle             SubscriptionCycle  @relation(fields: [cycleId], references: [id])
  offering          PodOffering        @relation(fields: [offeringId], references: [id])
  billingRecords    BillingRecord[]
  fulfillmentOrders FulfillmentOrder[]
}

// ---------------------------------------------------------------------------
// PDF generation
// ---------------------------------------------------------------------------

enum PrintFileStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

model GeneratedPrintFile {
  id                 String          @id @default(cuid())
  collectorProfileId String
  cycleId            String
  storageUrl         String?
  pageCount          Int?
  widthMm            Float?
  heightMm           Float?
  status             PrintFileStatus @default(PENDING)
  errorMessage       String?
  generatedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  collectorProfile CollectorProfile  @relation(fields: [collectorProfileId], references: [id], onDelete: Cascade)
  cycle            SubscriptionCycle @relation(fields: [cycleId], references: [id])
  fulfillmentOrder FulfillmentOrder?

  @@unique([collectorProfileId, cycleId])
}

// ---------------------------------------------------------------------------
// Checkout intent (Sprint 5 → Sprint 6 bridge)
// ---------------------------------------------------------------------------

model CheckoutIntent {
  id                         String   @id @default(cuid())
  collectorProfileId         String
  cycleId                    String
  committedAt                DateTime @default(now())
  selectionSnapshot          Json
  quoteInputCountry          String?
  quoteInputPageCount        Int?
  acceptedEstimateDisclaimer Boolean  @default(false)

  // Peecho order-based pricing fields
  peechoOrderId        String?
  retailTotalAmount    Decimal? @db.Decimal(10, 2)
  wholesaleTotalAmount Decimal? @db.Decimal(10, 2)
  platformMarkupAmount Decimal? @db.Decimal(10, 2)

  // Fulfillment mode: true = collector ordered manually before cycle lock
  orderedManually Boolean   @default(false)
  orderedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  collectorProfile CollectorProfile  @relation(fields: [collectorProfileId], references: [id], onDelete: Cascade)
  cycle            SubscriptionCycle @relation(fields: [cycleId], references: [id])

  @@unique([collectorProfileId, cycleId])
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------

enum BillingStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  GRACE_PERIOD
}

model BillingRecord {
  id                    String        @id @default(cuid())
  collectorProfileId    String
  cycleId               String
  quoteSnapshotId       String
  stripePaymentIntentId String?
  stripeInvoiceId       String?
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("EUR")
  status                BillingStatus @default(PENDING)
  paidAt                DateTime?
  errorMessage          String?

  // Peecho order-based pricing fields (from order details at cycle lock)
  peechoOrderId        String?
  retailTotalAmount    Decimal? @db.Decimal(10, 2)
  wholesaleTotalAmount Decimal? @db.Decimal(10, 2)
  platformMarkupAmount Decimal? @db.Decimal(10, 2)
  creatorPayoutAmount  Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  collectorProfile CollectorProfile     @relation(fields: [collectorProfileId], references: [id], onDelete: Cascade)
  cycle            SubscriptionCycle    @relation(fields: [cycleId], references: [id])
  quoteSnapshot    PricingQuoteSnapshot @relation(fields: [quoteSnapshotId], references: [id])

  @@unique([collectorProfileId, cycleId])
}

model StripeWebhookEvent {
  id          String   @id
  processedAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Platform configuration (singleton, admin-managed)
// ---------------------------------------------------------------------------

model PlatformConfig {
  id                   String   @id @default(cuid())
  // NOTE (Peecho quirk): The Peecho /quote endpoint returns wholesale prices
  // only — it does NOT include platform markup. The /order endpoint DOES
  // include the final retail price with markup baked in. To show collectors
  // an accurate price estimate, we add `quoteMarginAmount` on top of the
  // wholesale product price. This value must be kept in sync with whatever
  // margin is configured in the Peecho merchant dashboard.
  quoteMarginAmount    Float    @default(0.3) // fractional margin rate (e.g. 0.3 = 30%); markup = (productPrice + vat) * rate
  creatorPayoutSplit   Float    @default(0.7) // fraction of margin going to creators
  platformFeeSplit     Float    @default(0.3) // fraction of margin kept as platform fee
  maxArtworksPerRelease Int     @default(20) // maximum artworks allowed per release
  maxReleasesPerCycle   Int     @default(3)  // maximum releases a creator can publish per cycle
  updatedAt            DateTime @updatedAt
  updatedBy            String? // admin user ID who last updated

  @@index([updatedAt])
}

// ---------------------------------------------------------------------------
// Fulfillment
// ---------------------------------------------------------------------------

enum FulfillmentStatus {
  PENDING
  SUBMITTED
  PROCESSING
  SHIPPED
  DELIVERED
  FAILED
}

model FulfillmentOrder {
  id                   String            @id @default(cuid())
  collectorProfileId   String
  cycleId              String
  generatedPrintFileId String            @unique
  quoteSnapshotId      String
  providerOrderId      String?
  status               FulfillmentStatus @default(PENDING)
  trackingNumber       String?
  trackingUrl          String?
  errorMessage         String?
  submittedAt          DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  collectorProfile   CollectorProfile     @relation(fields: [collectorProfileId], references: [id], onDelete: Cascade)
  cycle              SubscriptionCycle    @relation(fields: [cycleId], references: [id])
  generatedPrintFile GeneratedPrintFile   @relation(fields: [generatedPrintFileId], references: [id])
  quoteSnapshot      PricingQuoteSnapshot @relation(fields: [quoteSnapshotId], references: [id])

  @@unique([collectorProfileId, cycleId])
}

// ---------------------------------------------------------------------------
// Creator payouts
// ---------------------------------------------------------------------------

enum PayoutStatus {
  PENDING
  SENT
  FAILED
}

model PayoutCalculation {
  id                       String   @id @default(cuid())
  cycleId                  String
  totalMarkupPool          Decimal  @db.Decimal(10, 2)
  totalPaidCollectors      Int
  totalFulfilledCollectors Int
  calculationSnapshot      Json
  calculatedAt             DateTime @default(now())
  createdAt                DateTime @default(now())

  cycle SubscriptionCycle @relation(fields: [cycleId], references: [id])

  @@unique([cycleId])
}

model CreatorPayout {
  id               String       @id @default(cuid())
  creatorProfileId String
  cycleId          String
  amount           Decimal      @db.Decimal(10, 2)
  currency         String       @default("EUR")
  status           PayoutStatus @default(PENDING)
  paypalBatchId    String?
  paypalPayoutId   String?
  calculatedAt     DateTime     @default(now())
  sentAt           DateTime?
  errorMessage     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  creatorProfile CreatorProfile    @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  cycle          SubscriptionCycle @relation(fields: [cycleId], references: [id])

  @@unique([creatorProfileId, cycleId])
}

// ---------------------------------------------------------------------------
// Creator profile views
// ---------------------------------------------------------------------------

model CreatorProfileView {
  id               String   @id @default(cuid())
  creatorProfileId String
  viewedAt         DateTime @default(now())
  cycleId          String?

  creatorProfile CreatorProfile     @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  cycle          SubscriptionCycle? @relation(fields: [cycleId], references: [id])
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

model NotificationPreference {
  id                     String  @id @default(cuid())
  userId                 String  @unique
  emailEnabled           Boolean @default(true)
  cycleReminderEnabled   Boolean @default(true)
  lockReminderEnabled    Boolean @default(true)
  releaseReminderEnabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EmailNotificationType {
  CREATOR_WELCOME
  CREATOR_ONBOARDING_INCOMPLETE
  CREATOR_RELEASE_REMINDER
  CREATOR_RELEASE_MISSING_WARNING
  CREATOR_RELEASE_PUBLISHED
  CREATOR_COLLECTOR_AT_RISK
  COLLECTOR_WELCOME
  COLLECTOR_SETUP_REMINDER
  COLLECTOR_PRICE_ESTIMATE
  COLLECTOR_SELECTION_REMINDER
  COLLECTOR_LOCK_REMINDER
  COLLECTOR_LOCK_CONFIRMED
  COLLECTOR_CREATOR_AT_RISK
  COLLECTOR_FULFILLMENT_BLOCKED
  COLLECTOR_AUTO_LOCK_REMINDER
  COLLECTOR_ORDER_CONFIRMED
  COLLECTOR_BOOKLET_SHIPPED
}

enum EmailNotificationStatus {
  PENDING
  SENT
  FAILED
}

model EmailNotificationLog {
  id        String                  @id @default(cuid())
  userId    String
  type      EmailNotificationType
  cycleId   String?
  status    EmailNotificationStatus @default(PENDING)
  sentAt    DateTime?
  errorMsg  String?
  createdAt DateTime                @default(now())

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle SubscriptionCycle? @relation(fields: [cycleId], references: [id])
}

// ---------------------------------------------------------------------------
// GTM Analytics - Lead Tracking and Attribution
// ---------------------------------------------------------------------------

enum LeadType {
  CREATOR
  COLLECTOR
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  QUALIFIED
  DISQUALIFIED
  SIGNED_UP
  ACTIVATED
}

enum EntryPageType {
  HOME
  CREATOR_PAGE
  BROWSE
  OTHER
}

model Lead {
  id               String     @id @default(cuid())
  email            String?
  type             LeadType
  status           LeadStatus @default(NEW)
  source           String? // instagram_dm, creator_link, deviantart_outreach
  campaign         String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmContent       String?
  utmTerm          String?
  referrerUrl      String?
  landingPath      String?
  creatorProfileId String?
  ownerUserId      String?    @unique
  notes            String?    @db.Text
  firstSeenAt      DateTime   @default(now())
  lastSeenAt       DateTime   @updatedAt
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  creatorProfile CreatorProfile?    @relation(fields: [creatorProfileId], references: [id])
  ownerUser      User?              @relation(fields: [ownerUserId], references: [id])
  events         LeadEvent[]
  sessions       AttributionSession[]

  @@index([type, status])
  @@index([creatorProfileId])
  @@index([source])
}

model LeadEvent {
  id         String   @id @default(cuid())
  leadId     String
  eventName  String
  eventValue String?
  metadata   Json?
  occurredAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, eventName])
  @@index([occurredAt])
}

model AttributionSession {
  id               String        @id @default(cuid())
  anonymousId      String        @unique
  leadId           String?
  firstPath        String
  lastPath         String
  referrerUrl      String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmContent       String?
  utmTerm          String?
  creatorProfileId String?
  entryPageType    EntryPageType @default(OTHER)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lead Lead? @relation(fields: [leadId], references: [id])

  @@index([anonymousId])
  @@index([leadId])
}
