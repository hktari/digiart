{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "extends": ["../../biome.json"],
  "linter": {
    "domains": {
      "next": "recommended",
      "react": "recommended"
    },
    "rules": {
      "performance": {
        "noImgElement": "off"
      },
      "a11y": {
        "noSvgWithoutTitle": "off",
        "useSemanticElements": "off",
        "useButtonType": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noUnknownAtRules": "off"
      }
    }
  }
}
