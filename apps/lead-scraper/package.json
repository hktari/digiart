{
  "name": "lead-scraper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "scrape": "tsx src/index.ts --daily",
    "scrape:test": "tsx src/index.ts --test",
    "scrape:dev": "pnpm --env-file=.env.dev run scrape:test",
    "browse": "tsx scripts/browse-leads.ts",
    "browse:dev": "pnpm --env-file=.env.dev run browse",
    "draft-outreach": "tsx scripts/draft-outreach.ts",
    "verify": "tsx scripts/verify-setup.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:push:dev": "pnpm --env-file=.env.dev prisma db push",
    "db:studio": "prisma studio",
    "db:studio:dev": "pnpm --env-file=.env.dev prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "lint": "biome check --write",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/community": "^0.3.18",
    "@langchain/core": "^0.3.23",
    "@langchain/langgraph": "^0.2.21",
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^4.5.0",
    "node-telegram-bot-api": "^0.66.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/node": "^20.19.39",
    "@types/node-telegram-bot-api": "^0.64.0",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
