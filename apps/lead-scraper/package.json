{
  "name": "lead-scraper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "scrape": "tsx src/index.ts --daily",
    "scrape:test": "tsx src/index.ts --test",
    "scrape:dev": "tsx --env-file=.env.dev src/index.ts --test",
    "browse": "tsx scripts/browse-leads.ts",
    "browse:dev": "tsx --env-file=.env.dev scripts/browse-leads.ts",
    "web": "USE_REACT=true tsx src/web/server.ts",
    "web:dev": "USE_REACT=true tsx --env-file=.env.dev src/web/server.ts",
    "web:legacy": "tsx src/web/server.ts",
    "web:legacy:dev": "tsx --env-file=.env.dev src/web/server.ts",
    "web:build": "cd web-ui && pnpm run build",
    "web:ui:dev": "cd web-ui && pnpm run dev",
    "draft-outreach": "tsx scripts/draft-outreach.ts",
    "draft-outreach:dev": "tsx --env-file=.env.dev scripts/draft-outreach.ts",
    "verify": "tsx scripts/verify-setup.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:push:dev": "dotenv -e .env.dev -- prisma db push",
    "db:studio": "prisma studio",
    "db:studio:dev": "dotenv -e .env.dev -- prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "lint": "biome check --write",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/community": "^0.3.59",
    "@langchain/core": "^0.3.80",
    "@langchain/langgraph": "^0.2.74",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^4.5.6",
    "grammy": "^1.43.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.41",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
