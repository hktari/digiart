# Lead Scraper - DEVELOPMENT Environment Variables
# This file shows the structure for .env.dev (development database)

# DEVELOPMENT Neon Database (safe to reset during testing)
# ⚠️ Use a SEPARATE database from production!
DATABASE_URL="postgresql://user:pass@ep-xxx-xxx.us-east-2.aws.neon.tech/lead_scraper_dev?sslmode=require"

# Fireworks AI
FIREWORKS_API_KEY="your-fireworks-key"

# Telegram Bot (optional - can use same as production or separate test bot)
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

# Optional: Enable debug logging
DEBUG=false

# LangSmith (optional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
