# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Database (same Neon project as apps/mvp)
DATABASE_URL="postgresql://user:password@localhost:5432/mvp_db"

# Storage
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="/tmp/booklets"

# AWS S3 (production storage)
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
# Set this to use MinIO locally instead of real S3:
# AWS_ENDPOINT_URL="http://localhost:9000"

# App
PORT=3001
